<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive Room database -->
        <exclude domain="database" path="ascenso_db"/>
        <exclude domain="database" path="ascenso_db-shm"/>
        <exclude domain="database" path="ascenso_db-wal"/>

        <!-- Exclude sensitive shared preferences -->
        <exclude domain="sharedpref" path="penalty_prefs_secure.xml"/>
        <exclude domain="sharedpref" path="penalty_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- For device transfer, we might allow it if encryption is handled, 
             but for safety we exclude it here too if it's very sensitive -->
        <exclude domain="database" path="ascenso_db"/>
        <exclude domain="sharedpref" path="penalty_prefs_secure.xml"/>
    </device-transfer>
</data-extraction-rules>
